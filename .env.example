# ─── PREDCHAIN PRODUCTION ENVIRONMENT TEMPLATE ───
# Duplicate this file to .env.local for local development.
# Copy these keys to your Vercel Dashboard for production deployment.

# 🟢 SUPABASE CONFIGURATION (Found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-DO-NOT-EXPOSE-TO-CLIENT

# 💳 PAYSTACK INTEGRATION (Found in Dashboard > Settings > API Keys)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_SECRET_KEY=sk_test_...

# 📧 EMAIL INTEGRATION (Optional - e.g. Resend)
RESEND_API_KEY=re_your_key

# 🌐 APP METADATA
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
